{
  "manifest_version": 3,
  "name": "AIFuel Live Feed",
  "version": "1.5.0",
  "description": "Real-time AI usage monitor. Shows rate limits, cost tracking, and reset countdowns for Claude and other providers.",
  "permissions": [
    "cookies",
    "nativeMessaging",
    "alarms",
    "storage",
    "notifications"
  ],
  "host_permissions": [
    "https://claude.ai/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "AIFuel Usage Monitor"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  }
}
